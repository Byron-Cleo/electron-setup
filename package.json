{
  "name": "pos-billing-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:react": "vite",
    "dev:react:network": "vite --host",
    "dev:electron": "tsc --project desktop/electron/tsconfig.json && concurrently -k -n \"tsc,app\" \"tsc --project desktop/electron/tsconfig.json --watch --preserveWatchOutput\" \"nodemon --watch dist-electron -e js --exec cross-env NODE_ENV=development electron .\"",
    "dev": "concurrently -k -n \"react,electron\" \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:all": "concurrently -k -n \"backend,react,electron\" \"npm run dev:backend\" \"npm run dev:react\" \"npm run dev:electron\"",
    "db:sync": "npm run db:generate --prefix backend && npm run db:push --prefix backend",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "transpile:electron": "tsc --project desktop/electron/tsconfig.json",
    "build:mac": "tsc -b && vite build && electron-builder --mac --config electron-builder.json",
    "build:win": "tsc -b && vite build && electron-builder --win --config electron-builder.json",
    "build:linux": "tsc -b && vite build && electron-builder --linux --config electron-builder.json",
    "build:all": "tsc -b && vite build && electron-builder --mac --win --linux --config electron-builder.json"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^5.4.0",
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.21.0",
    "os-utils": "^0.0.14",
    "radix-ui": "^1.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.79.0",
    "react-router-dom": "^7.18.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/os-utils": "^0.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
