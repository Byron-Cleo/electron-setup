{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".opencode/skills/feature/SKILL.md",
    ".opencode/skills/deepseek-frontend/SKILL.md",
    ".opencode/skills/qwen-backend/SKILL.md",
    ".opencode/skills/qwen-vision/SKILL.md"
  ],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "references": {
    "context": {
      "path": "context",
      "description": "Use for project overview, coding standards, AI interaction guidelines, current feature tracking, and all project documentation"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true,
      "env": {
        "BROWSER": "chromium"
      }
    }
  }
}
