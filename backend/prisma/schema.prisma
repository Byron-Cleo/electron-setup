generator client {
  provider = "prisma-client"
  output   = "../db/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  userId            String   @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Cart {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String?  @db.Uuid
  sessionCartId String
  items         Json[]   @default([]) @db.Json
  itemsPrice    Decimal  @db.Decimal(12, 2)
  totalPrice    Decimal  @db.Decimal(12, 2)
  shippingPrice Decimal  @db.Decimal(12, 2)
  taxPrice      Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  updatedAt     DateTime
  User          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Menu {
  id                                                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                                  String
  slug                                                  String                @unique(map: "product_slug_idx")
  category                                              String
  images                                                String[]
  brand                                                 String
  description                                           String
  stock                                                 Int
  price                                                 Decimal               @default(0) @db.Decimal(12, 2)
  rating                                                Decimal               @default(0) @db.Decimal(3, 2)
  numReviews                                            Int                   @default(0)
  isFeatured                                            Boolean               @default(false)
  banner                                                String?
  createdAt                                             DateTime              @default(now()) @db.Timestamp(6)
  starchId                                              String?               @db.Uuid
  vegetableId                                           String?               @db.Uuid
  MenuAccompaniment_Menu_starchIdToMenuAccompaniment    MenuAccompaniment?    @relation("Menu_starchIdToMenuAccompaniment", fields: [starchId], references: [id])
  MenuAccompaniment_Menu_vegetableIdToMenuAccompaniment MenuAccompaniment?    @relation("Menu_vegetableIdToMenuAccompaniment", fields: [vegetableId], references: [id])
  MenuMealType                                          MenuMealType[]
  OrderItem                                             OrderItem[]
  Review                                                Review[]
  StockSupply                                           StockSupply[]
}

model MenuAccompaniment {
  id                                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                     String
  category                                 AccompanimentType
  description                              String?
  price                                    Decimal? @db.Decimal(12, 2)
  image         String
  createdAt                                DateTime @default(now()) @db.Timestamp(6)
  isDefault                                Boolean  @default(false)
  Menu_Menu_starchIdToMenuAccompaniment       Menu[]       @relation("Menu_starchIdToMenuAccompaniment")
  Menu_Menu_vegetableIdToMenuAccompaniment    Menu[]       @relation("Menu_vegetableIdToMenuAccompaniment")
  OrderItem_starchIdToMenuAccompaniment       OrderItem[]  @relation("OrderItem_starchIdToMenuAccompaniment")
  OrderItem_vegetableIdToMenuAccompaniment    OrderItem[]  @relation("OrderItem_vegetableIdToMenuAccompaniment")
}

model Order {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String        @db.Uuid
  mealType        ServiceTime
  shippingAddress Json          @db.Json
  paymentMethod   String
  paymentResult   Json?         @db.Json
  itemsPrice      Decimal       @db.Decimal(12, 2)
  shippingPrice   Decimal       @db.Decimal(12, 2)
  taxPrice        Decimal       @db.Decimal(12, 2)
  totalPrice      Decimal       @db.Decimal(12, 2)
  isPaid          Boolean       @default(false)
  paidAt          DateTime?     @db.Timestamp(6)
  isDelivered     Boolean       @default(false)
  deliveredAt     DateTime?     @db.Timestamp(6)
  createdAt       DateTime      @default(now()) @db.Timestamp(6)
  User            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  OrderItem       OrderItem[]
}

model OrderItem {
  orderId     String              @db.Uuid
  menuId      String              @db.Uuid
  qty         Int
  price       Decimal             @db.Decimal(12, 2)
  name        String
  slug        String
  image       String
  starchId    String?             @db.Uuid
  vegetableId String?             @db.Uuid
  Menu        Menu                @relation(fields: [menuId], references: [id], onDelete: Cascade)
  Order       Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  Starch      MenuAccompaniment?  @relation("OrderItem_starchIdToMenuAccompaniment", fields: [starchId], references: [id])
  Vegetable   MenuAccompaniment?  @relation("OrderItem_vegetableIdToMenuAccompaniment", fields: [vegetableId], references: [id])

  @@id([orderId, menuId], map: "orderitems_orderIdmenuId_pk")
}

model Review {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String   @db.Uuid
  menuId             String   @db.Uuid
  rating             Int
  title              String
  description        String
  isVerifiedPurchase Boolean  @default(true)
  createdAt          DateTime @default(now()) @db.Timestamp(6)
  Menu               Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  User               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  sessionToken String   @id
  userId       String   @db.Uuid
  expires      DateTime @db.Timestamp(6)
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String    @default("NO_NAME")
  email         String    @unique(map: "user_email_idx")
  emailVerified DateTime? @db.Timestamp(6)
  image         String?
  password      String?
  pin           String?
  role          String    @default("staff")
  isActive      Boolean   @default(true)
  platform      String?
  address       Json?     @db.Json
  paymentMethod String?
  createdAt     DateTime  @default(now()) @db.Timestamp(6)
  updatedAt     DateTime
  Account       Account[]
  Cart          Cart[]
  Order         Order[]
  Review        Review[]
  Session       Session[]
  StockRequest  StockRequest[]
  fulfillments  StockFulfillment[]
  cookingRecords CookingRecord[]
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model MenuMealType {
  menuId   String      @db.Uuid
  mealType ServiceTime
  Menu     Menu        @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([menuId, mealType])
}

enum ServiceTime {
  BREAKFAST
  LUNCH
  DINNER
  DESSERT
  BEVERAGE
}

enum AccompanimentType {
  STARCH
  VEGETABLE
}

enum ItemUnit {
  KG
  G
  L
  ML
  PCS
}

enum StockRequestStatus {
  PENDING
  PARTIAL
  COMPLETED
}

model StockSupply {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  slug          String             @unique
  description   String?
  unit          ItemUnit
  currentStock  Decimal            @default(0) @db.Decimal(12, 2)
  reorderLevel  Decimal?           @db.Decimal(12, 2)
  platesPerUnit Decimal?           @db.Decimal(12, 2)
  menuId        String?            @db.Uuid
  image         String?
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  menu          Menu?              @relation(fields: [menuId], references: [id])
  StockRequestItem StockRequestItem[]
  DepartmentStockSupply DepartmentStockSupply[]
  CookingRecord CookingRecord[]
}

model StockRequest {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestedById String             @db.Uuid
  department    String
  status        StockRequestStatus @default(PENDING)
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  requestedBy   User               @relation(fields: [requestedById], references: [id])
  items         StockRequestItem[]
  fulfillments  StockFulfillment[]
}

model StockRequestItem {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stockRequestId    String       @db.Uuid
  stockSupplyId     String       @db.Uuid
  quantityRequested Decimal      @db.Decimal(12, 2)
  quantityDelivered Decimal      @default(0) @db.Decimal(12, 2)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  stockRequest      StockRequest @relation(fields: [stockRequestId], references: [id], onDelete: Cascade)
  stockSupply       StockSupply  @relation(fields: [stockSupplyId], references: [id])
  fulfillmentItems  StockFulfillmentItem[]
}

model Department {
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  description      String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  DepartmentStockSupply DepartmentStockSupply[]
}

model DepartmentStockSupply {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  departmentId   String          @db.Uuid
  stockSupplyId  String          @db.Uuid
  createdAt      DateTime        @default(now())
  department     Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  stockSupply    StockSupply     @relation(fields: [stockSupplyId], references: [id], onDelete: Cascade)

  @@unique([departmentId, stockSupplyId])
}

model StockFulfillment {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stockRequestId  String            @db.Uuid
  fulfilledById   String            @db.Uuid
  notes           String?
  createdAt       DateTime          @default(now())
  stockRequest    StockRequest      @relation(fields: [stockRequestId], references: [id], onDelete: Cascade)
  fulfilledBy     User              @relation(fields: [fulfilledById], references: [id])
  items           StockFulfillmentItem[]
}

model StockFulfillmentItem {
  id                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stockFulfillmentId   String            @db.Uuid
  stockRequestItemId   String            @db.Uuid
  quantityDelivered    Decimal           @db.Decimal(12, 2)
  createdAt            DateTime          @default(now())
  stockFulfillment     StockFulfillment  @relation(fields: [stockFulfillmentId], references: [id], onDelete: Cascade)
  stockRequestItem     StockRequestItem  @relation(fields: [stockRequestItemId], references: [id])
}

model CookingRecord {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stockSupplyId   String      @db.Uuid
  quantityCooked  Decimal     @db.Decimal(12, 2)
  platesExpected  Decimal     @db.Decimal(12, 2)
  cookedById      String      @db.Uuid
  notes           String?
  createdAt       DateTime    @default(now())
  stockSupply     StockSupply @relation(fields: [stockSupplyId], references: [id])
  cookedBy        User        @relation(fields: [cookedById], references: [id])
}
