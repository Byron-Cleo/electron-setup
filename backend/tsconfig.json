{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["index.ts", "app.ts", "db.ts", "routes/**/*.ts", "generated/**/*.ts", "db/sample-data.ts", "db/seed.ts"],
  "exclude": ["node_modules", "dist", "prisma"]
}
